APP_NAME=Website Generator Platform
ENVIRONMENT=development
DEBUG=true

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=wgp_session
SESSION_TTL_HOURS=12

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

REAL_PROVIDER_CALLS_ENABLED=false
PROMPT_TEMPLATE_VERSION=v1

OPENAI_API_KEY=
OPENAI_MODEL_REFINE=gpt-5-mini
OPENAI_MODEL_DESIGN=gpt-5
OPENAI_MODEL_BUILD=gpt-5

GEMINI_API_KEY=
GEMINI_MODEL_REFINE=gemini-2.5-flash
GEMINI_MODEL_DESIGN=gemini-2.5-pro
GEMINI_MODEL_BUILD=gemini-2.5-pro

CLAUDE_API_KEY=
CLAUDE_MODEL_REFINE=claude-3-7-sonnet-latest
CLAUDE_MODEL_DESIGN=claude-sonnet-4-0
CLAUDE_MODEL_BUILD=claude-sonnet-4-0

DEEPSEEK_API_KEY=
